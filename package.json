{
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter @blxzer/trellis-core build && pnpm --filter @blxzer/trellis build",
    "build:core": "pnpm --filter @blxzer/trellis-core build",
    "build:cli": "pnpm --filter @blxzer/trellis build",
    "test": "pnpm --filter @blxzer/trellis-core test && pnpm --filter @blxzer/trellis test",
    "test:core": "pnpm --filter @blxzer/trellis-core test",
    "test:cli": "pnpm --filter @blxzer/trellis test",
    "lint": "pnpm --filter @blxzer/trellis-core lint && pnpm --filter @blxzer/trellis lint",
    "typecheck": "pnpm --filter @blxzer/trellis-core build && pnpm --filter @blxzer/trellis typecheck",
    "release": "pnpm --filter @blxzer/trellis release",
    "release:minor": "pnpm --filter @blxzer/trellis release:minor",
    "release:major": "pnpm --filter @blxzer/trellis release:major",
    "release:beta": "pnpm --filter @blxzer/trellis release:beta",
    "release:rc": "pnpm --filter @blxzer/trellis release:rc",
    "release:promote": "pnpm --filter @blxzer/trellis release:promote",
    "release:check": "node packages/cli/scripts/release-preflight.js check-versions",
    "release:plan": "node packages/cli/scripts/release-preflight.js publish-plan"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
