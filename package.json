{
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter @blxzer/cursor-trellis-core build && pnpm --filter @blxzer/cursor-trellis build",
    "build:core": "pnpm --filter @blxzer/cursor-trellis-core build",
    "build:cli": "pnpm --filter @blxzer/cursor-trellis build",
    "test": "pnpm --filter @blxzer/cursor-trellis-core test && pnpm --filter @blxzer/cursor-trellis test",
    "test:core": "pnpm --filter @blxzer/cursor-trellis-core test",
    "test:cli": "pnpm --filter @blxzer/cursor-trellis test",
    "lint": "pnpm --filter @blxzer/cursor-trellis-core lint && pnpm --filter @blxzer/cursor-trellis lint",
    "typecheck": "pnpm --filter @blxzer/cursor-trellis-core build && pnpm --filter @blxzer/cursor-trellis typecheck",
    "release": "pnpm --filter @blxzer/cursor-trellis release",
    "release:minor": "pnpm --filter @blxzer/cursor-trellis release:minor",
    "release:major": "pnpm --filter @blxzer/cursor-trellis release:major",
    "release:beta": "pnpm --filter @blxzer/cursor-trellis release:beta",
    "release:rc": "pnpm --filter @blxzer/cursor-trellis release:rc",
    "release:promote": "pnpm --filter @blxzer/cursor-trellis release:promote",
    "release:check": "node packages/cli/scripts/release-preflight.js check-versions",
    "release:plan": "node packages/cli/scripts/release-preflight.js publish-plan"
  }
}
