{
  "name": "@blxzer/cursor-trellis",
  "version": "0.3.0",
  "description": "AI capabilities grow like ivy — Trellis provides the structure to guide them along a disciplined path",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cstl": "./bin/cstl.js",
    "smart-search": "./bin/smart-search.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run clean && tsc && pnpm run copy-templates",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "copy-templates": "node scripts/copy-templates.js",
    "postinstall": "node scripts/postinstall.js",
    "check:pack-files": "node scripts/check-cli-pack-files.js",
    "check:release-pack": "node scripts/check-release-pack-contents.js",
    "check:router-copy-sync": "node scripts/check-router-copy-sync.js",
    "check:router-copy-sync:hash": "node scripts/check-router-copy-sync.js --hash-only",
    "mirror-check": "node scripts/mirror-check.js",
    "copy:release-assets": "node scripts/copy-release-assets.js",
    "sync:pack-files": "node scripts/sync-cli-pack-files.js",
    "dev": "tsc --watch",
    "start": "node ./dist/cli/index.js",
    "test": "vitest run --maxWorkers=4",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "lint:py": "basedpyright",
    "lint:all": "pnpm lint && pnpm lint:py",
    "prepublishOnly": "pnpm test && pnpm run build && pnpm run copy:release-assets",
    "release": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:beta": "node scripts/release.js beta",
    "release:rc": "node scripts/release.js rc",
    "release:promote": "node scripts/release.js promote",
    "release:publish": "node scripts/publish-packages.js",
    "release:publish:dry": "node scripts/publish-packages.js --dry-run",
    "manifest": "node scripts/create-manifest.js"
  },
  "keywords": [
    "ai",
    "workflow",
    "cursor",
    "claude",
    "iflow",
    "cli",
    "developer-tools",
    "agent",
    "memory",
    "trellis"
  ],
  "author": "Mindfold LLC",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@blxzer/cursor-trellis-core": "workspace:*",
    "@blxzer/smart-search": "^0.1.15",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "figlet": "^1.9.4",
    "giget": "^3.1.1",
    "inquirer": "^9.3.7",
    "undici": "^6.21.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/figlet": "^1.7.0",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.17.10",
    "@vitest/coverage-v8": "^4.0.18",
    "basedpyright": "^1.37.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.21.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "files": [
    "dist",
    "bin",
    "scripts/postinstall.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/blxzer77/cursor-trellis.git"
  }
}
